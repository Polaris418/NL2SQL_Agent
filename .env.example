NL2SQL_MASTER_KEY=change-me-in-production
NL2SQL_METADATA_DB=./metadata.sqlite3
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
DEFAULT_QUERY_LIMIT=1000
MAX_CONCURRENT_QUERIES=5
QUERY_TIMEOUT_SECONDS=30
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CHROMA_PERSIST_DIRECTORY=./chroma
POSTGRESQL_DRIVER=postgresql+psycopg
MYSQL_DRIVER=mysql+pymysql
SQLITE_DRIVER=sqlite+pysqlite
